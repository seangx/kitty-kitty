{
  "name": "kitty-kitty",
  "version": "0.1.0",
  "description": "Desktop pet with AI chat and session management",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test:mcp": "node scripts/mcp-regression.js && node scripts/mcp-config-regression.js && node scripts/mcp-stability-regression.js",
    "verify": "npm run test:mcp && npm run build",
